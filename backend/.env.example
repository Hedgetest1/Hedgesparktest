# =============================================================================
# WishSpark / Hedge Spark — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before starting any process.
# Secrets marked [REQUIRED] must be set before public exposure.
# Secrets marked [OPTIONAL] degrade gracefully when absent.
#
# After editing .env, reload all PM2 processes:
#   pm2 reload ecosystem.config.js
# =============================================================================


# -----------------------------------------------------------------------------
# Database  [REQUIRED]
# -----------------------------------------------------------------------------
# PostgreSQL connection string.  App refuses to start if this is missing.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/wishspark


# -----------------------------------------------------------------------------
# Shopify App credentials  [REQUIRED for OAuth and webhook verification]
# -----------------------------------------------------------------------------
# Obtain from: Shopify Partner Dashboard → Apps → <your app> → API credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Obtain from: Shopify Partner Dashboard → Apps → <your app> → Webhooks
# → Add webhook → orders/paid → copy the signing secret shown after creation.
# Without this value, POST /webhooks/shopify/orders-paid accepts all requests
# without signature verification — anyone can inject fake order data.
SHOPIFY_WEBHOOK_SECRET=

# The public HTTPS URL where this backend is reachable (no trailing slash).
# Used to build the Shopify OAuth callback URL registered in Shopify Partner Dashboard:
#   <APP_URL>/auth/callback
# Also used to build the orders/paid webhook URL:
#   <APP_URL>/webhooks/shopify/orders-paid
# Also used as the default tracker Script Tag URL:
#   <APP_URL>/tracker.js
APP_URL=https://api.hedgesparkhq.com

# The public HTTPS URL of the merchant-facing dashboard (no trailing slash).
# Merchants are redirected here after completing OAuth install:
#   <DASHBOARD_URL>/?shop=example.myshopify.com&installed=1&webhook=ok&tracker=ok
DASHBOARD_URL=https://app.hedgesparkhq.com

# Override the tracker script URL injected as a Shopify Script Tag during install.
# Default: {APP_URL}/tracker.js
# Set this if the tracker is served from a CDN or different origin.
# TRACKER_SCRIPT_URL=https://cdn.hedgesparkhq.com/tracker.js


# -----------------------------------------------------------------------------
# Token encryption  [REQUIRED for production / App Store]
# -----------------------------------------------------------------------------
# 32-byte key for AES-256-GCM encryption of Shopify merchant access tokens.
# Tokens are stored encrypted in merchants.access_token.
# Without this, tokens are stored as plaintext (degraded security posture).
#
# Generate:  python3 -c "import os; print(os.urandom(32).hex())"
#
# KEY ROTATION: changing this key means existing encrypted tokens cannot be
# decrypted.  Run a migration script to re-encrypt all rows before rotating.
# Existing PLAINTEXT rows (written before this key was set) are still readable
# transparently — only encrypted rows require the matching key.
MERCHANT_TOKEN_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# Dashboard API key  [REQUIRED for Pro endpoint security]
# -----------------------------------------------------------------------------
# Shared secret between the Next.js dashboard and this backend.
# Sent by the dashboard as the X-API-Key header on all authenticated requests.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Without this value, all /pro/* endpoints skip API key enforcement.
DASHBOARD_API_KEY=
# During operator key rotation, set the old key here temporarily.
# Remove after all clients switch to the new key.
DASHBOARD_API_KEY_PREV=


# -----------------------------------------------------------------------------
# OpenAI  [REQUIRED for AI nudge composer]
# -----------------------------------------------------------------------------
# Used by POST /pro/nudges (AI copy generation via gpt-4o-mini).
# Without this, the AI composer falls back to rule-based copy generation.
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# Redis  [REQUIRED for session and cache features]
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# Email  [OPTIONAL — daily brief emails]
# -----------------------------------------------------------------------------
# Obtain from: https://resend.com/api-keys
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# Orchestrator mode  [OPTIONAL — AI decision layer]
# -----------------------------------------------------------------------------
# deterministic = rules only (default, safe)
# proposal      = rules + Claude proposes actions (logged, NOT executed)
# hybrid        = rules execute + Claude proposals execute (future)
ORCHESTRATOR_MODE=deterministic
# LLM provider routing
# Preferred provider: anthropic (default) | openai
LLM_PREFERRED_PROVIDER=anthropic
# Allow fallback to other provider if preferred is unavailable
# false (default) = no call if preferred unavailable; true = try other provider
LLM_ALLOW_FALLBACK=false
# Anthropic API key for Claude-driven orchestrator proposals
# Not set = LLM layer disabled, deterministic rules only
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Operator alerts  [OPTIONAL — Slack delivery]
# -----------------------------------------------------------------------------
# Slack incoming webhook URL for operator alerts (critical/warning).
# Not set = alerts are DB-only (queryable via /ops/alerts API).
# Create at: https://api.slack.com/messaging/webhooks
OPS_SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Error tracking  [OPTIONAL — Sentry Team plan recommended]
# -----------------------------------------------------------------------------
# Obtain from: https://sentry.io → Project Settings → Client Keys (DSN)
# HedgeSpark runs on the EU region (de.sentry.io) — GDPR-friendly.
SENTRY_DSN=

# Environment tag on every event ("production", "staging", "dev"). Affects
# default sample rates: dev/staging default to 0.0 to avoid quota burn.
SENTRY_ENVIRONMENT=production

# Release identifier — prefer `hedgespark@<git-sha-12>`. If unset,
# app/core/sentry_init.py falls back to `git rev-parse HEAD`. Set this
# explicitly in CI / deploy.sh so every event carries the exact SHA.
SENTRY_RELEASE=

# Performance sample rates (Team plan). Errors are always 100%.
# Base trace rate: 5% in prod, 0% in dev. High-value endpoints
# (/auth/, /billing/, /webhooks/) sampled at 4× via TracesSampler.
SENTRY_TRACES_SAMPLE_RATE=0.05
# Profiling sample rate (Team plan). 10% of traced transactions get
# a profile flame graph. Dev defaults to 0.
SENTRY_PROFILES_SAMPLE_RATE=0.10

# Webhook intake (bypasses email parsing, signed POST to /webhooks/sentry/inbound)
# Obtain from: Sentry → Settings → Integrations → Internal Integrations → Webhook Secret
SENTRY_WEBHOOK_SECRET=

# Sentry CLI auth token (optional — only needed for scripts/sentry_notify_release.sh
# and Next.js source-maps upload). Scope: releases + project:releases.
SENTRY_AUTH_TOKEN=
# Organization slug for sentry-cli commands.
SENTRY_ORG=
# Project slug for sentry-cli commands.
SENTRY_PROJECT=


# -----------------------------------------------------------------------------
# Klaviyo  [OPTIONAL — per-merchant Klaviyo push integration]
# -----------------------------------------------------------------------------
# Merchants pass their own Klaviyo Private API Key per request to POST /pro/klaviyo/push.
# No server-side storage needed in v1 — keys are passed at request time.
# Future: per-merchant storage in the merchants table (klaviyo_api_key column).


# -----------------------------------------------------------------------------
# Shopify Billing  [REQUIRED for Pro plan subscriptions]
# -----------------------------------------------------------------------------
# Price shown to merchants on the Shopify billing confirmation page.
# Must match what is listed in your Shopify Partner Dashboard app listing.
SHOPIFY_PRO_PLAN_PRICE=29.00

# Name shown on the Shopify billing confirmation page.
SHOPIFY_PRO_PLAN_NAME=Hedge Spark Pro

# Free trial days for new Pro subscribers (0 = no trial).
SHOPIFY_PRO_TRIAL_DAYS=14


# -----------------------------------------------------------------------------
# Development safety bypass  [NEVER set in production]
# -----------------------------------------------------------------------------
# When set to "true", allows the server to start without SHOPIFY_WEBHOOK_SECRET
# and DASHBOARD_API_KEY — bypassing HMAC verification and API key enforcement.
#
# This is ONLY for private local development where no real merchant data exists.
# Production and any publicly reachable deployment must NEVER have this set.
#
# Default: unset (safe — enforcement is always active unless explicitly bypassed).
# ALLOW_INSECURE_DEV=true
