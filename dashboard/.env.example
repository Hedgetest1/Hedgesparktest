# Dashboard environment template — copy to .env.local and fill in.
# .env.local is gitignored.

# ----------------------------------------------------------------------
# Backend API
# ----------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://api.hedgesparkhq.com
# Server-side API key for server actions / SSR fetches that need auth.
NEXT_PUBLIC_DASHBOARD_API_KEY=

# ----------------------------------------------------------------------
# Sentry (browser + SSR + edge)  [OPTIONAL — Team plan recommended]
# ----------------------------------------------------------------------
# DSN — same pattern as the backend. EU region (de.sentry.io) by default.
# NEXT_PUBLIC_ prefix is required for client-side bundles.
# Leave empty to disable Sentry on the dashboard (graceful no-op).
NEXT_PUBLIC_SENTRY_DSN=

# Environment tag (production / staging / dev). Sample rates auto-zero
# in non-production envs to avoid quota burn during local dev.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Release identifier — set by CI to match the backend release.
# Format: hedgespark@<git-sha-12>.
NEXT_PUBLIC_SENTRY_RELEASE=

# Tunnel route through our own /monitoring path to bypass ad-blockers.
# Set to "1" to enable; default disabled.
NEXT_PUBLIC_SENTRY_TUNNEL=

# Server-side source-map upload credentials (used by next build via
# withSentryConfig). Required only at build time, not at runtime.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
