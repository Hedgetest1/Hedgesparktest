# Environment — never commit
backend/.env
**/.env

# Python
__pycache__/
*.pyc
*.pyo
backend/venv/
**/*.egg-info/

# Node / Dashboard
dashboard/node_modules/
dashboard/.next/

# Stray Next.js trace files written from wrong CWD (root)
/.next/

# Operator-local Claude Code state (.claude/skills/ and .claude/agents/
# are committed source — see CLAUDE.md §25). Local settings + scheduled
# task locks are operational state, not source.
.claude/settings.local.json
.claude/scheduled_tasks.lock
backend/.claude/
dashboard/.claude/

# Sandbox run data (operational, not source)
sandbox/

# Logs
logs/
*.log

# Filebrowser — operational, contains user DB (credentials)
filebrowser-data/

# Founder-uploaded refs / screenshots (via filebrowser)
screenshots/

# Operational backups dir
backups/

# Backup files
*.backup
*.backup.*
*.bak

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
.testmondata
