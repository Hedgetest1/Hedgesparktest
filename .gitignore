# Environment — never commit
backend/.env
**/.env

# Python
__pycache__/
*.pyc
*.pyo
backend/venv/
**/*.egg-info/

# Node / Dashboard
dashboard/node_modules/
dashboard/.next/

# Sandbox run data (operational, not source)
sandbox/

# Logs
logs/
*.log

# Filebrowser — operational, contains user DB (credentials)
filebrowser-data/

# Founder-uploaded refs / screenshots (via filebrowser)
screenshots/

# Operational backups dir
backups/

# Backup files
*.backup
*.backup.*
*.bak

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
.testmondata
