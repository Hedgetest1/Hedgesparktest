# -----------------------------------------------------------------------------
# HedgeSpark — staging environment template (ε2)
# -----------------------------------------------------------------------------
# Copy to /opt/wishspark-stage/.env and fill in the values for the staging box.
# Staging runs on a separate subdomain (stage.hedgesparkhq.com) behind the same
# Traefik instance as production, with a dedicated Postgres and Redis.
#
# Rollout flow:
#   1. `git push origin main`
#   2. CI/CD (or manual): ./scripts/deploy_staging.sh
#   3. Smoke tests run automatically against stage.hedgesparkhq.com
#   4. On green, ./deploy.sh promotes main → prod
#
# Every env var here MUST differ from prod. Never reuse secrets.
# -----------------------------------------------------------------------------

# --- Core ---
ENVIRONMENT=staging
APP_URL=https://stage.hedgesparkhq.com
APP_DASHBOARD_URL=https://stage-app.hedgesparkhq.com
APP_API_URL=https://stage-api.hedgesparkhq.com

# --- Database ---
# Staging Postgres — separate instance, NEVER shared with prod
DATABASE_URL=postgresql+psycopg2://hs_stage:REPLACE_ME@localhost:5432/hedgespark_stage
DATABASE_SSL=
# Optional read replica (ε1)
# DATABASE_READ_URL=postgresql+psycopg2://hs_stage_ro:REPLACE_ME@localhost:5432/hedgespark_stage

# --- Redis ---
# Separate db index so flushes don't wipe prod
REDIS_URL=redis://localhost:6379/2

# --- Shopify OAuth (staging app in Shopify Partners) ---
# Create a SECOND Shopify app for staging — DO NOT reuse prod credentials
SHOPIFY_API_KEY=REPLACE_ME
SHOPIFY_API_SECRET=REPLACE_ME
SHOPIFY_SCOPES=read_orders,read_products,read_script_tags,write_script_tags,read_customers,read_discounts,write_discounts
SHOPIFY_APP_HANDLE=hedgespark-stage

# --- Encryption keys ---
# MUST be different from prod. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=REPLACE_ME
MERCHANT_SESSION_SECRET=REPLACE_ME

# --- LLM budget (tight for staging) ---
LLM_MONTHLY_BUDGET_EUR=2.0
ANTHROPIC_API_KEY=REPLACE_ME
OPENAI_API_KEY=REPLACE_ME

# --- Feature flags ---
AUTO_MERGE_TIER0=0           # NEVER auto-merge on staging
NUDGE_BANDIT_ENABLED=1        # test bandit here before prod
PRODUCT_EMBEDDING_BACKEND=hash

# --- Observability ---
SENTRY_DSN=REPLACE_ME_STAGING_DSN
SENTRY_ENVIRONMENT=staging

# --- Ops / Telegram ---
OPS_API_KEY=REPLACE_ME
TELEGRAM_BOT_TOKEN=REPLACE_ME_STAGING_BOT
TELEGRAM_CHAT_ID=REPLACE_ME_STAGING_CHAT
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME

# --- Public events (ζ3) ---
PUBLIC_EVENTS_DEV_SECRET=REPLACE_ME_STAGING_HMAC

# --- Event bus ---
EVENT_BUS_BACKEND=postgres    # flip to 'clickhouse' when ClickHouse is deployed
EVENT_BUS_RETENTION_DAYS=30    # shorter on staging to save disk
